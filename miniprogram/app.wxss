/* ==============================
   VocabMaster 全局样式
   ============================== */

page {
  --primary: #3b82f6;
  --primary-light: #60a5fa;
  --primary-bg: rgba(59, 130, 246, 0.08);
  --text: #1e293b;
  --text-secondary: #64748b;
  --text-hint: #94a3b8;
  --bg: #f5f7fa;
  --card-bg: #ffffff;
  --border: #e2e8f0;
  --success: #22c55e;
  --danger: #ef4444;
  --shadow-card: 0 4px 20px rgba(59, 130, 246, 0.08), 0 1px 4px rgba(0,0,0,0.04);
  --shadow-float: 0 10px 40px rgba(59, 130, 246, 0.12), 0 2px 8px rgba(0,0,0,0.04);
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background-color: var(--bg);
  box-sizing: border-box;
}

/* 玻璃卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: var(--shadow-card);
  border-radius: var(--radius-lg);
}

/* 渐变按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  letter-spacing: 2rpx;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  opacity: 0.5;
}

/* 幽灵按钮 */
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  padding: 16rpx;
}

.btn-ghost::after { border: none; }

/* 进度条 */
.progress-track {
  height: 6rpx;
  background: var(--border);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #6366f1);
  border-radius: 3rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 分割线 */
.divider {
  width: 80rpx;
  height: 2rpx;
  background: var(--border);
}