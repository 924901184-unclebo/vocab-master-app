/* 词卡复习页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---- 顶部 ---- */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 8rpx;
}

.progress-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
}

.counter {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.speak-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
}

.icon-sm {
  width: 36rpx;
  height: 36rpx;
}

.icon-xs {
  width: 24rpx;
  height: 24rpx;
}

/* ---- 进度条 ---- */
.progress-wrap {
  padding: 0 32rpx 24rpx;
}

/* ---- 中心状态 ---- */
.center-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
}

.empty-img {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 40rpx;
  opacity: 0.8;
}

.state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ---- Swiper 词卡 ---- */
.card-swiper {
  flex: 1;
  padding: 0 16rpx;
}

.vocab-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 16rpx;
  padding: 56rpx 40rpx 32rpx;
  height: calc(100% - 32rpx);
  box-sizing: border-box;
}

.card-term {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1rpx;
  text-align: center;
  line-height: 1.2;
  word-break: break-word;
}

.card-phonetic {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-family: 'Courier New', monospace;
  margin-top: 12rpx;
}

.vocab-card .divider {
  margin: 36rpx 0;
}

.card-meaning {
  font-size: 30rpx;
  color: var(--text);
  text-align: center;
  line-height: 1.7;
  max-width: 520rpx;
}

.card-context {
  margin-top: 28rpx;
  padding: 0 16rpx;
}

.context-text {
  font-size: 24rpx;
  color: var(--text-hint);
  font-style: italic;
  text-align: center;
  line-height: 1.6;
}

.card-source {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 36rpx;
}

.source-text {
  font-size: 22rpx;
  color: var(--primary);
}

.swipe-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
  padding-top: 24rpx;
}

.hint-arrow {
  font-size: 24rpx;
  color: var(--text-hint);
  opacity: 0.3;
}

.hint-text {
  font-size: 20rpx;
  color: var(--text-hint);
  opacity: 0.4;
}

/* ---- 底部按钮 ---- */
.bottom-action {
  padding: 16rpx 32rpx 32rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  border: none;
  font-size: 28rpx;
}

.refresh-btn::after {
  border: none;
}

.refresh-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
}