/* 添加页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---- 页面标题 ---- */
.page-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 32rpx 32rpx 16rpx;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
  margin-top: 4rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.header-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* ---- URL 输入 ---- */
.input-section {
  margin: 16rpx 32rpx 24rpx;
  padding: 28rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  width: 40rpx;
  height: 40rpx;
  padding: 8rpx;
  background: var(--primary-bg);
  border-radius: 12rpx;
  box-sizing: content-box;
}

.url-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.parse-btn {
  gap: 8rpx;
}

.icon-spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ---- 进度条 ---- */
.progress-section {
  margin: 0 32rpx 24rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-stage {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.progress-pct {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
}

/* ---- 结果列表 ---- */
.result-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 16rpx;
}

.result-count {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text);
}

.toggle-all {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--primary);
}

.term-list {
  flex: 1;
  padding: 0 32rpx;
}

.term-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.item-disabled {
  opacity: 0.5;
}

.term-check {
  padding-top: 4rpx;
}

.check-on {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--primary);
  position: relative;
}

.check-on::after {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 12rpx;
  width: 12rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg);
}

.check-off {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border);
  box-sizing: border-box;
}

.check-exists {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--border);
  font-size: 20rpx;
  color: var(--text-hint);
  display: flex;
  align-items: center;
  justify-content: center;
}

.term-info {
  flex: 1;
  min-width: 0;
}

.term-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.term-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.tag-exists {
  font-size: 18rpx;
  font-weight: 500;
  color: var(--text-hint);
  background: var(--bg);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.term-meaning {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ---- 确认栏 ---- */
.confirm-bar {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border);
}

/* ---- 空引导 ---- */
.empty-guide {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
}

.guide-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: var(--primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.guide-icon {
  width: 60rpx;
  height: 60rpx;
}

.guide-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  max-width: 400rpx;
}