/* 词库页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ---- 标题 ---- */
.page-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 32rpx 32rpx 16rpx;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
  margin-top: 4rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.header-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

/* ---- 搜索栏 ---- */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 8rpx 32rpx 16rpx;
  padding: 20rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-x {
  font-size: 24rpx;
  color: var(--text-hint);
}

.search-hint {
  padding: 0 36rpx 16rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ---- 中心状态 ---- */
.center-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.state-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.empty-search-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.2;
  margin-bottom: 24rpx;
}

/* ---- 词汇列表 ---- */
.word-list {
  flex: 1;
  padding: 0 32rpx;
}

.letter-group {
  margin-bottom: 24rpx;
}

.letter-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  position: sticky;
  top: 0;
  z-index: 5;
  padding: 4rpx 0;
  background: var(--bg);
}

.letter-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: var(--primary-bg);
  font-size: 22rpx;
  font-weight: 700;
  color: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.letter-line {
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

/* ---- 词条 ---- */
.word-item {
  margin-bottom: 12rpx;
  overflow: hidden;
}

.word-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
}

.word-brief {
  flex: 1;
  min-width: 0;
}

.word-term {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.word-meaning-short {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expand-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
  opacity: 0.4;
  transition: transform 0.2s ease;
}

.expand-arrow.expanded {
  transform: rotate(90deg);
}

/* ---- 详情展开 ---- */
.word-detail {
  padding: 0 28rpx 24rpx;
}

.detail-divider {
  height: 1rpx;
  background: var(--border);
  margin-bottom: 20rpx;
}

.detail-phonetic {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-family: 'Courier New', monospace;
  display: block;
  margin-bottom: 12rpx;
}

.detail-meaning {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.detail-context {
  font-size: 24rpx;
  color: var(--text-hint);
  font-style: italic;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.detail-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: transparent;
  border: none;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.action-btn::after { border: none; }

.action-icon {
  width: 28rpx;
  height: 28rpx;
}

.action-spacer {
  flex: 1;
}

.action-danger {
  color: var(--danger);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}